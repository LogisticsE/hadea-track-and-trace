# Environment variables — set these in the Vercel dashboard under Settings > Environment Variables

# Flask session signing key — use a long random string (required for login to persist)
SECRET_KEY=change-me-to-a-long-random-string

# Login credentials
APP_USERNAME=admin
APP_PASSWORD=admin

# Power BI Azure AD app credentials
PBI_CLIENT_ID=bf4e6c9c-2fe5-4eb2-9e05-2785f8c2c42a
PBI_CLIENT_SECRET=your-client-secret-here
PBI_TENANT_ID=c94e2732-29d6-41d6-89d9-08c9798a6601

# Power BI report
PBI_WORKSPACE_ID=7e8075a9-3b1f-430a-827e-b7f65d591c69
PBI_REPORT_ID=6d7bf2e6-e8b1-4d92-814d-1120d38053fb
